// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id            String         @id @default(cuid())
  title         String
  bpm           Int?
  key           String?
  status        Status         @default(NEEDS_WORK)
  sections      Section[]
  setlistSongs  SetlistSong[]
  practiceNotes PracticeNote[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Section {
  id        String   @id @default(cuid())
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  type      String
  label     String?
  status    Status   @default(NEEDS_WORK)
  lyrics    String?
  chords    String?
  bassTab   String?
  notes     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setlist {
  id        String        @id @default(cuid())
  title     String
  date      DateTime?
  songs     SetlistSong[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SetlistSong {
  id        String  @id @default(cuid())
  setlistId String
  setlist   Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  songId    String
  song      Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  order     Int     @default(0)

  @@unique([setlistId, songId])
}

model PracticeNote {
  id        String   @id @default(cuid())
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

enum Status {
  PERFORMANCE_READY
  GETTING_THERE
  NEEDS_WORK
}
